{% extends "public/layout/base.html.twig" %}

{% block page_title %}
    {{ 'public.register.title'|trans }}
{% endblock %}

{% block page_class %}page-center{% endblock %}

{% block header %}{% endblock %}

{% block page_body %}
    <main class="container container-narrow py-4">
        {% block main %}
            {{ form_start(form, { 'attr': { 'class': 'card card-md' } }) }}
                <div class="card-status-top bg-primary"></div>
                <div class="card-body">
                    <h2 class="card-title text-center mb-4">
                        <a href="{{ path('home') }}" class="navbar-brand navbar-brand-autodark">
                            <img src="{{ appConfig.appLogo }}" alt="{{ appConfig.appName }}" style="max-height: 30px;">
                        </a>
                    </h2>
                    <div class="row">
                        <div class="col-md-6">
                            {{ form_row(form.name) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.lastname) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.email) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.phone) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.birthdate) }}
                        </div>
                        <div class="col-md-6">
                            {{ form_row(form.gender) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.plainPassword) }}
                        </div>
                        <div class="col-12">
                            {{ form_row(form.acceptTerms) }}
                        </div>
                    </div>
                    <div class="form-footer">
                        <div class="row gap-2">
                            <div class="col-12 text-center">
                                <small class="text-muted">{{ 'public.register.registerText'|trans }}</small>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary w-100">
                                    <twig:ux:icon class="icon" name="tabler:check" /> {{ 'public.register.registerBtn'|trans }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            {{ form_end(form) }}
        {% endblock %}
    </main>
{% endblock %}

{% block footer %}{% endblock %}

{% block js %}
    {{ parent() }}

    {{ importmap('form-type-date') }}
{% endblock %}
